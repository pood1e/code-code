{
  "name": "agent-workbench",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @agent-workbench/shared --filter @agent-workbench/backend --filter @agent-workbench/frontend dev",
    "start:e2e": "pnpm --filter @agent-workbench/backend prisma db push --accept-data-loss --skip-generate && pnpm --filter @agent-workbench/backend seed && (pnpm --filter @agent-workbench/frontend preview & pnpm --filter @agent-workbench/backend start)",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:migrate": "pnpm --filter @agent-workbench/backend prisma migrate dev",
    "db:seed": "pnpm --filter @agent-workbench/backend prisma db seed"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.46.2"
  }
}
