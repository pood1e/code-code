generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Skill {
  id          String         @id @default(cuid())
  name        String
  description String?
  content     String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  profileLinks ProfileSkill[]
}

model MCP {
  id          String       @id @default(cuid())
  name        String
  description String?
  /// MCP server config following the stdio server protocol shape.
  /// type: transport type, fixed to "stdio" in this phase.
  /// command: executable command to launch the MCP server process.
  /// args: ordered command-line arguments passed to the process.
  /// env: optional string map of environment variables for the process.
  content     Json
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  profileLinks ProfileMCP[]
}

model Rule {
  id          String        @id @default(cuid())
  name        String
  description String?
  content     String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  profileLinks ProfileRule[]
}

model Profile {
  id          String         @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  skills      ProfileSkill[]
  mcps        ProfileMCP[]
  rules       ProfileRule[]
}

model Project {
  id            String   @id @default(cuid())
  name          String
  description   String?
  gitUrl        String
  workspacePath String
  docSource     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  sessions      AgentSession[]
  chats         Chat[]
  pipelines     Pipeline[]
  repositoryProfiles RepositoryProfile[]
  governanceFindings Finding[]
  governanceIssues Issue[]
  governanceMergeRecords FindingMergeRecord[]
  governanceExecutionAttempts GovernanceExecutionAttempt[]
  governanceReviewDecisions ReviewDecision[]
  governanceDeliveryArtifacts DeliveryArtifact[]
  governancePolicy GovernancePolicy?
  notificationChannels NotificationChannel[]
  notificationTasks NotificationTask[]
}

model GovernancePolicy {
  id               String   @id @default(cuid())
  scopeId          String   @unique
  priorityPolicy   Json
  autoActionPolicy Json
  deliveryPolicy   Json
  runnerSelection  Json
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@index([scopeId], name: "idx_governance_policy_scope_id")
}

model GovernanceExecutionAttempt {
  id                    String   @id @default(cuid())
  scopeId               String
  stageType             String
  subjectType           String
  subjectId             String
  attemptNo             Int
  status                String   @default("pending")
  sessionId             String?  @unique
  activeRequestMessageId String?
  ownerLeaseToken       String?
  leaseExpiresAt        DateTime?
  inputSnapshot         Json?
  candidateOutput       Json?
  parsedOutput          Json?
  failureCode           String?
  failureMessage        String?
  resolvedByReviewDecisionId String?
  startedAt             DateTime?
  finishedAt            DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  project               Project  @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  session               AgentSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@unique([stageType, subjectType, subjectId, attemptNo], name: "uq_governance_execution_attempt_subject_attempt")
  @@index([scopeId], name: "idx_governance_execution_attempt_scope_id")
  @@index([stageType, subjectType, subjectId], name: "idx_governance_execution_attempt_subject")
  @@index([status, leaseExpiresAt], name: "idx_governance_execution_attempt_lease")
}

model RepositoryProfile {
  id          String   @id @default(cuid())
  scopeId      String
  branch      String
  snapshotAt  DateTime
  modules     Json
  testBaseline Json
  buildStatus String   @default("unknown")
  metadata    Json?
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  project     Project  @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@index([scopeId], name: "idx_repository_profile_scope_id")
  @@index([scopeId, snapshotAt], name: "idx_repository_profile_scope_snapshot_at")
}

model Finding {
  id               String   @id @default(cuid())
  scopeId          String
  source           String
  sourceRef        String?
  title            String
  summary          String
  evidence         Json
  categories       Json
  tags             Json
  severityHint     String?
  confidence       Float?
  affectedTargets  Json
  metadata         Json?
  fingerprint      String?
  discoveredAt     DateTime @default(now())
  status           String   @default("pending")
  ownerLeaseToken  String?
  leaseExpiresAt   DateTime?
  version          Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@index([scopeId], name: "idx_finding_scope_id")
  @@index([status], name: "idx_finding_status")
  @@index([status, leaseExpiresAt], name: "idx_finding_lease")
  @@index([scopeId, fingerprint], name: "idx_finding_scope_fingerprint")
}

model Issue {
  id                 String   @id @default(cuid())
  scopeId            String
  title              String
  statement          String
  kind               String
  categories         Json
  tags               Json
  relatedFindingIds  Json
  status             String   @default("open")
  affectedTargets    Json
  rootCause          String?
  impactSummary      String
  isRegression       Boolean  @default(false)
  regressionOfIssueId String?
  spinOffOfIssueId   String?
  ownerLeaseToken    String?
  leaseExpiresAt     DateTime?
  version            Int      @default(1)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  project            Project  @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  mergeRecords       FindingMergeRecord[]
  assessments        IssueAssessment[]
  resolutionDecisions ResolutionDecision[]
  changePlans        ChangePlan[]
  changeUnits        ChangeUnit[]
  verificationPlans  VerificationPlan[]
  verificationResults VerificationResult[]
  deliveryArtifacts  DeliveryArtifact[]

  @@index([scopeId], name: "idx_issue_scope_id")
  @@index([status], name: "idx_issue_status")
  @@index([status, leaseExpiresAt], name: "idx_issue_lease")
}

model FindingMergeRecord {
  id              String   @id @default(cuid())
  scopeId         String
  targetIssueId   String
  mergedFindingIds Json
  trigger         String
  clusterBasis    Json?
  mergedBy        String?
  mergedAt        DateTime
  createdAt       DateTime @default(now())
  project         Project  @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  targetIssue     Issue    @relation(fields: [targetIssueId], references: [id], onDelete: Cascade)

  @@index([scopeId], name: "idx_finding_merge_scope_id")
  @@index([targetIssueId], name: "idx_finding_merge_target_issue_id")
}

model IssueAssessment {
  id                    String   @id @default(cuid())
  issueId               String
  severity              String
  priority              String
  userImpact            Int
  systemRisk            Int
  strategicValue        Int
  fixCost               Int
  autoActionEligibility String
  rationale             Json
  assessedBy            String
  assessedAt            DateTime
  createdAt             DateTime @default(now())
  issue                 Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId], name: "idx_issue_assessment_issue_id")
}

model ResolutionDecision {
  id            String   @id @default(cuid())
  issueId       String
  resolution    String
  reason        String
  deferUntil    DateTime?
  primaryIssueId String?
  approvedBy    String?
  decidedAt     DateTime
  createdAt     DateTime @default(now())
  issue         Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([issueId], name: "idx_resolution_decision_issue_id")
}

model ChangePlan {
  id              String   @id @default(cuid())
  issueId         String
  objective       String
  strategy        String
  affectedTargets Json
  proposedActions Json
  risks           Json
  rollbackPlan    String?
  assumptions     Json?
  baselineCommitSha String
  status          String   @default("draft")
  ownerLeaseToken String?
  leaseExpiresAt  DateTime?
  version         Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  issue           Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  changeUnits     ChangeUnit[]
  verificationPlans VerificationPlan[]
  verificationResults VerificationResult[]
  deliveryArtifacts DeliveryArtifact[]

  @@index([issueId], name: "idx_change_plan_issue_id")
  @@index([status], name: "idx_change_plan_status")
  @@index([status, leaseExpiresAt], name: "idx_change_plan_lease")
}

model ChangeUnit {
  id               String   @id @default(cuid())
  changePlanId     String
  issueId          String
  sourceActionId   String
  dependsOnUnitIds Json
  title            String
  description      String
  scope            Json
  executionMode    String
  maxRetries       Int      @default(3)
  currentAttemptNo Int      @default(0)
  status           String   @default("pending")
  producedCommitIds Json
  ownerLeaseToken  String?
  leaseExpiresAt   DateTime?
  version          Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  changePlan       ChangePlan @relation(fields: [changePlanId], references: [id], onDelete: Cascade)
  issue            Issue      @relation(fields: [issueId], references: [id], onDelete: Cascade)
  verificationPlans VerificationPlan[]
  verificationResults VerificationResult[]

  @@index([changePlanId], name: "idx_change_unit_change_plan_id")
  @@index([issueId], name: "idx_change_unit_issue_id")
  @@index([status], name: "idx_change_unit_status")
  @@index([status, leaseExpiresAt], name: "idx_change_unit_lease")
}

model VerificationPlan {
  id          String   @id @default(cuid())
  subjectType String
  changeUnitId String?
  changePlanId String?
  issueId     String?
  checks      Json
  passCriteria Json
  createdAt   DateTime @default(now())
  changeUnit  ChangeUnit? @relation(fields: [changeUnitId], references: [id], onDelete: Cascade)
  changePlan  ChangePlan? @relation(fields: [changePlanId], references: [id], onDelete: Cascade)
  issue       Issue?      @relation(fields: [issueId], references: [id], onDelete: Cascade)
  verificationResults VerificationResult[]

  @@index([subjectType], name: "idx_verification_plan_subject_type")
  @@index([changeUnitId], name: "idx_verification_plan_change_unit_id")
  @@index([changePlanId], name: "idx_verification_plan_change_plan_id")
  @@index([issueId], name: "idx_verification_plan_issue_id")
}

model VerificationResult {
  id                String   @id @default(cuid())
  verificationPlanId String
  subjectType       String
  changeUnitId      String?
  changePlanId      String?
  issueId           String?
  executionAttemptNo Int
  status            String
  checkResults      Json
  summary           String
  executedAt        DateTime
  createdAt         DateTime @default(now())
  verificationPlan  VerificationPlan @relation(fields: [verificationPlanId], references: [id], onDelete: Cascade)
  changeUnit        ChangeUnit? @relation(fields: [changeUnitId], references: [id], onDelete: Cascade)
  changePlan        ChangePlan? @relation(fields: [changePlanId], references: [id], onDelete: Cascade)
  issue             Issue? @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@index([verificationPlanId], name: "idx_verification_result_plan_id")
  @@index([changeUnitId], name: "idx_verification_result_change_unit_id")
  @@index([changePlanId], name: "idx_verification_result_change_plan_id")
  @@index([issueId], name: "idx_verification_result_issue_id")
}

model DeliveryArtifact {
  id                        String   @id @default(cuid())
  scopeId                   String
  issueId                   String
  changePlanId              String?
  kind                      String
  title                     String
  body                      String
  linkedIssueIds            Json
  linkedChangeUnitIds       Json
  linkedVerificationResultIds Json
  bodyStrategy              String
  externalRef               String?
  status                    String   @default("submitted")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  project                   Project  @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  issue                     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  changePlan                ChangePlan? @relation(fields: [changePlanId], references: [id], onDelete: SetNull)

  @@index([scopeId], name: "idx_delivery_artifact_scope_id")
  @@index([issueId], name: "idx_delivery_artifact_issue_id")
  @@index([changePlanId], name: "idx_delivery_artifact_change_plan_id")
  @@index([status], name: "idx_delivery_artifact_status")
}

model ReviewDecision {
  id                String   @id @default(cuid())
  scopeId           String
  subjectType       String
  subjectId         String
  decision          String
  assessmentOverride Json?
  comment           String?
  reviewer          String
  createdAt         DateTime @default(now())
  project           Project  @relation(fields: [scopeId], references: [id], onDelete: Cascade)

  @@index([scopeId], name: "idx_review_decision_scope_id")
  @@index([subjectType, subjectId], name: "idx_review_decision_subject")
}

model AgentRunner {
  id           String         @id @default(cuid())
  name         String
  description  String?
  type         String
  runnerConfig Json
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AgentSession[]
  pipelines    Pipeline[]
}

model ProfileSkill {
  id             String   @id @default(cuid())
  profileId      String
  skillId        String
  order          Int
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill          Skill    @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@unique([profileId, skillId])
  @@unique([profileId, order])
}

model ProfileMCP {
  id             String   @id @default(cuid())
  profileId      String
  mcpId          String
  order          Int
  configOverride Json?
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  mcp            MCP      @relation(fields: [mcpId], references: [id], onDelete: Restrict)

  @@unique([profileId, mcpId])
  @@unique([profileId, order])
}

model ProfileRule {
  id             String   @id @default(cuid())
  profileId      String
  ruleId         String
  order          Int
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  rule           Rule     @relation(fields: [ruleId], references: [id], onDelete: Restrict)

  @@unique([profileId, ruleId])
  @@unique([profileId, order])
}

model AgentSession {
  id                     String           @id @default(cuid())
  runnerId               String
  runner                 AgentRunner      @relation(fields: [runnerId], references: [id], onDelete: Restrict)
  runnerType             String
  scopeId                String
  status                 String
  lastEventId            Int              @default(0)
  activeAssistantMessageId String?
  platformSessionConfig  Json
  runnerSessionConfig    Json
  defaultRuntimeConfig   Json?
  runnerState            Json?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  project                Project          @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  messages               SessionMessage[]
  toolUses               MessageToolUse[]
  metrics                SessionMetric[]
  events                 SessionEvent[]
  chat                   Chat?
  pipelineStage          PipelineStage?
  stageAttempts          StageExecutionAttempt[]
  governanceAttempts     GovernanceExecutionAttempt[]

  @@index([scopeId])
}

model SessionMessage {
  id           String           @id @default(cuid())
  sessionId    String
  role         String
  status       String
  inputContent Json?
  runtimeConfig Json?
  outputText   String?
  thinkingText String?
  contentParts Json?
  errorPayload Json?
  cancelledAt  DateTime?
  eventId      Int?
  createdAt    DateTime         @default(now())
  session      AgentSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  toolUses     MessageToolUse[]
  metrics      SessionMetric[]

  @@index([sessionId])
  @@unique([sessionId, eventId])
}

model MessageToolUse {
  id        String         @id @default(cuid())
  sessionId String
  messageId String
  eventId   Int
  callId    String?
  toolKind  String         @default("fallback")
  toolName  String
  args      Json?
  result    Json?
  error     Json?
  createdAt DateTime       @default(now())
  session   AgentSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message   SessionMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([messageId])
  @@unique([sessionId, eventId])
}

model SessionMetric {
  id        String       @id @default(cuid())
  sessionId String
  messageId String?
  eventId   Int
  kind      String
  data      Json
  createdAt DateTime     @default(now())
  session   AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message   SessionMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, messageId])
  @@unique([sessionId, eventId])
}

model SessionEvent {
  id          String       @id @default(cuid())
  sessionId   String
  eventId     Int
  kind        String
  messageId   String?
  timestampMs BigInt
  data        Json?
  createdAt   DateTime     @default(now())
  session     AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@unique([sessionId, eventId])
}

model NotificationChannel {
  id           String   @id @default(cuid())
  scopeId      String
  name         String
  capabilityId String
  config       Json
  filter       Json
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  tasks        NotificationTask[]

  @@unique([scopeId, name], name: "uq_channel_scope_name")
  @@index([scopeId], name: "idx_channel_scope_id")
}

model NotificationTask {
  id         String   @id @default(cuid())
  scopeId    String
  channelId  String?
  channelName String
  messageId  String
  messageType String
  message    Json
  status     String   @default("pending")
  lastError  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  channel    NotificationChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@unique([messageId, channelId], name: "uq_tasks_message_channel")
  @@index([status, createdAt], name: "idx_tasks_status_created_at")
  @@index([status, updatedAt], name: "idx_tasks_status_updated_at")
  @@index([messageId], name: "idx_tasks_message_id")
  @@index([scopeId], name: "idx_tasks_scope_id")
  @@index([channelId], name: "idx_tasks_channel_id")
}

model Chat {
  id        String       @id @default(cuid())
  scopeId   String
  sessionId String       @unique
  title     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  project   Project      @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  session   AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([scopeId], name: "idx_chat_scope_id")
}

model Pipeline {
  id             String             @id @default(cuid())
  scopeId        String
  runnerId       String?
  name           String
  description    String?
  featureRequest String?
  status         String             @default("draft")
  lastEventId    Int                @default(0)
  currentStageId String?
  executionOwnerId String?
  executionLeaseExpiresAt DateTime?
  version        Int                @default(1)
  state          Json?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  project        Project            @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  runner         AgentRunner?       @relation(fields: [runnerId], references: [id], onDelete: Restrict)
  stages         PipelineStage[]
  artifacts      PipelineArtifact[]
  artifactSeries PipelineArtifactSeries[]
  events         PipelineEvent[]

  @@index([scopeId], name: "idx_pipeline_scope_id")
  @@index([status], name: "idx_pipeline_status")
  @@index([runnerId], name: "idx_pipeline_runner_id")
  @@index([status, executionLeaseExpiresAt], name: "idx_pipeline_execution_lease")
}

model PipelineArtifactSeries {
  pipelineId  String
  artifactKey String
  nextVersion Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  pipeline    Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@id([pipelineId, artifactKey])
  @@index([pipelineId], name: "idx_pipeline_artifact_series_pipeline_id")
}


model PipelineStage {
  id         String             @id @default(cuid())
  pipelineId String
  name       String
  stageType  String
  order      Int
  status     String             @default("pending")
  retryCount Int                @default(0)
  state      Json?
  sessionId  String?            @unique
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  pipeline   Pipeline           @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  session    AgentSession?      @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  artifacts  PipelineArtifact[]
  attempts   StageExecutionAttempt[]

  @@index([pipelineId], name: "idx_pipeline_stage_pipeline_id")
  @@unique([pipelineId, order], name: "uq_pipeline_stage_order")
}

model StageExecutionAttempt {
  id                    String   @id @default(cuid())
  stageId               String
  attemptNo             Int
  status                String   @default("pending")
  sessionId             String?  @unique
  activeRequestMessageId String?
  ownerLeaseToken       String?
  leaseExpiresAt        DateTime?
  reviewReason          String?
  failureCode           String?
  failureMessage        String?
  resolvedAgentConfig   Json?
  inputSnapshot         Json?
  candidateOutput       Json?
  parsedOutput          Json?
  startedAt             DateTime?
  finishedAt            DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  stage                 PipelineStage @relation(fields: [stageId], references: [id], onDelete: Cascade)
  session               AgentSession?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([stageId], name: "idx_stage_execution_attempt_stage_id")
  @@index([status, leaseExpiresAt], name: "idx_stage_execution_attempt_lease")
  @@unique([stageId, attemptNo], name: "uq_stage_execution_attempt_stage_attempt")
}

model PipelineArtifact {
  id          String         @id @default(cuid())
  pipelineId  String
  stageId     String?
  artifactKey String?
  attempt     Int?
  version     Int?
  status      String         @default("pending")
  materializerOwnerId String?
  materializerLeaseExpiresAt DateTime?
  name        String
  contentType String
  storageRef  String?
  content     String?
  lastError   String?
  materializeAttempts Int    @default(0)
  metadata    Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  pipeline    Pipeline       @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stage       PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)

  @@index([pipelineId], name: "idx_pipeline_artifact_pipeline_id")
  @@index([stageId], name: "idx_pipeline_artifact_stage_id")
  @@index([status, updatedAt], name: "idx_pipeline_artifact_status_updated_at")
  @@index([status, materializerLeaseExpiresAt], name: "idx_pipeline_artifact_materializer_lease")
  @@unique([pipelineId, artifactKey, version], name: "uq_pipeline_artifact_version")
}

model PipelineEvent {
  id          String   @id @default(cuid())
  pipelineId  String
  eventId     Int
  kind        String
  stageId     String?
  stageType   String?
  timestampMs BigInt
  data        Json?
  createdAt   DateTime @default(now())
  pipeline    Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@unique([pipelineId, eventId], name: "uq_pipeline_event_id")
  @@index([pipelineId], name: "idx_pipeline_event_pipeline_id")
}
