generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Skill {
  id          String         @id @default(cuid())
  name        String
  description String?
  content     String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  profileLinks ProfileSkill[]
}

model MCP {
  id          String       @id @default(cuid())
  name        String
  description String?
  /// MCP server config following the stdio server protocol shape.
  /// type: transport type, fixed to "stdio" in this phase.
  /// command: executable command to launch the MCP server process.
  /// args: ordered command-line arguments passed to the process.
  /// env: optional string map of environment variables for the process.
  content     Json
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  profileLinks ProfileMCP[]
}

model Rule {
  id          String        @id @default(cuid())
  name        String
  description String?
  content     String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  profileLinks ProfileRule[]
}

model Profile {
  id          String         @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  skills      ProfileSkill[]
  mcps        ProfileMCP[]
  rules       ProfileRule[]
}

model Project {
  id            String   @id @default(cuid())
  name          String
  description   String?
  gitUrl        String
  workspacePath String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  sessions      AgentSession[]
}

model AgentRunner {
  id           String   @id @default(cuid())
  name         String
  description  String?
  type         String
  runnerConfig Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ProfileSkill {
  id             String   @id @default(cuid())
  profileId      String
  skillId        String
  order          Int
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill          Skill    @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@unique([profileId, skillId])
  @@unique([profileId, order])
}

model ProfileMCP {
  id             String   @id @default(cuid())
  profileId      String
  mcpId          String
  order          Int
  configOverride Json?
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  mcp            MCP      @relation(fields: [mcpId], references: [id], onDelete: Restrict)

  @@unique([profileId, mcpId])
  @@unique([profileId, order])
}

model ProfileRule {
  id             String   @id @default(cuid())
  profileId      String
  ruleId         String
  order          Int
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  rule           Rule     @relation(fields: [ruleId], references: [id], onDelete: Restrict)

  @@unique([profileId, ruleId])
  @@unique([profileId, order])
}

model AgentSession {
  id                     String           @id @default(cuid())
  runnerId               String
  runnerType             String
  scopeId                String
  status                 String
  lastEventId            Int              @default(0)
  activeAssistantMessageId String?
  platformSessionConfig  Json
  runnerSessionConfig    Json
  defaultRuntimeConfig   Json?
  runnerState            Json?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  project                Project          @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  messages               SessionMessage[]
  toolUses               MessageToolUse[]
  metrics                SessionMetric[]
  events                 SessionEvent[]

  @@index([scopeId])
}

model SessionMessage {
  id           String        @id @default(cuid())
  sessionId    String
  role         String
  status       String
  inputContent Json?
  outputText   String?
  thinkingText String?
  errorPayload Json?
  cancelledAt  DateTime?
  eventId      Int?
  createdAt    DateTime      @default(now())
  session      AgentSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  metrics      SessionMetric[]

  @@index([sessionId])
  @@unique([sessionId, eventId])
}

model MessageToolUse {
  id        String       @id @default(cuid())
  sessionId String
  messageId String
  eventId   Int
  callId    String?
  toolName  String
  args      Json?
  result    Json?
  error     Json?
  createdAt DateTime     @default(now())
  session   AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([messageId])
  @@unique([sessionId, eventId])
}

model SessionMetric {
  id        String       @id @default(cuid())
  sessionId String
  messageId String?
  eventId   Int
  kind      String
  data      Json
  createdAt DateTime     @default(now())
  session   AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message   SessionMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, messageId])
  @@unique([sessionId, eventId])
}

model SessionEvent {
  id          String       @id @default(cuid())
  sessionId   String
  eventId     Int
  kind        String
  messageId   String?
  timestampMs BigInt
  data        Json?
  createdAt   DateTime     @default(now())
  session     AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@unique([sessionId, eventId])
}
