generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Skill {
  id          String         @id @default(cuid())
  name        String
  description String?
  content     String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  profileLinks ProfileSkill[]
}

model MCP {
  id          String       @id @default(cuid())
  name        String
  description String?
  /// MCP server config following the stdio server protocol shape.
  /// type: transport type, fixed to "stdio" in this phase.
  /// command: executable command to launch the MCP server process.
  /// args: ordered command-line arguments passed to the process.
  /// env: optional string map of environment variables for the process.
  content     Json
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  profileLinks ProfileMCP[]
}

model Rule {
  id          String        @id @default(cuid())
  name        String
  description String?
  content     String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  profileLinks ProfileRule[]
}

model Profile {
  id          String         @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  skills      ProfileSkill[]
  mcps        ProfileMCP[]
  rules       ProfileRule[]
}

model Project {
  id            String   @id @default(cuid())
  name          String
  description   String?
  gitUrl        String
  workspacePath String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  sessions      AgentSession[]
  notificationChannels NotificationChannel[]
  notificationTasks NotificationTask[]
}

model AgentRunner {
  id           String         @id @default(cuid())
  name         String
  description  String?
  type         String
  runnerConfig Json
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AgentSession[]
}

model ProfileSkill {
  id             String   @id @default(cuid())
  profileId      String
  skillId        String
  order          Int
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill          Skill    @relation(fields: [skillId], references: [id], onDelete: Restrict)

  @@unique([profileId, skillId])
  @@unique([profileId, order])
}

model ProfileMCP {
  id             String   @id @default(cuid())
  profileId      String
  mcpId          String
  order          Int
  configOverride Json?
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  mcp            MCP      @relation(fields: [mcpId], references: [id], onDelete: Restrict)

  @@unique([profileId, mcpId])
  @@unique([profileId, order])
}

model ProfileRule {
  id             String   @id @default(cuid())
  profileId      String
  ruleId         String
  order          Int
  profile        Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  rule           Rule     @relation(fields: [ruleId], references: [id], onDelete: Restrict)

  @@unique([profileId, ruleId])
  @@unique([profileId, order])
}

model AgentSession {
  id                     String           @id @default(cuid())
  runnerId               String
  runner                 AgentRunner      @relation(fields: [runnerId], references: [id], onDelete: Restrict)
  runnerType             String
  scopeId                String
  status                 String
  lastEventId            Int              @default(0)
  activeAssistantMessageId String?
  platformSessionConfig  Json
  runnerSessionConfig    Json
  defaultRuntimeConfig   Json?
  runnerState            Json?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  project                Project          @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  messages               SessionMessage[]
  toolUses               MessageToolUse[]
  metrics                SessionMetric[]
  events                 SessionEvent[]

  @@index([scopeId])
}

model SessionMessage {
  id           String           @id @default(cuid())
  sessionId    String
  role         String
  status       String
  inputContent Json?
  runtimeConfig Json?
  outputText   String?
  thinkingText String?
  contentParts Json?
  errorPayload Json?
  cancelledAt  DateTime?
  eventId      Int?
  createdAt    DateTime         @default(now())
  session      AgentSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  toolUses     MessageToolUse[]
  metrics      SessionMetric[]

  @@index([sessionId])
  @@unique([sessionId, eventId])
}

model MessageToolUse {
  id        String         @id @default(cuid())
  sessionId String
  messageId String
  eventId   Int
  callId    String?
  toolKind  String         @default("fallback")
  toolName  String
  args      Json?
  result    Json?
  error     Json?
  createdAt DateTime       @default(now())
  session   AgentSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message   SessionMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([messageId])
  @@unique([sessionId, eventId])
}

model SessionMetric {
  id        String       @id @default(cuid())
  sessionId String
  messageId String?
  eventId   Int
  kind      String
  data      Json
  createdAt DateTime     @default(now())
  session   AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  message   SessionMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, messageId])
  @@unique([sessionId, eventId])
}

model SessionEvent {
  id          String       @id @default(cuid())
  sessionId   String
  eventId     Int
  kind        String
  messageId   String?
  timestampMs BigInt
  data        Json?
  createdAt   DateTime     @default(now())
  session     AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@unique([sessionId, eventId])
}

model NotificationChannel {
  id           String   @id @default(cuid())
  scopeId      String
  name         String
  capabilityId String
  config       Json
  filter       Json
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  project      Project  @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  tasks        NotificationTask[]

  @@unique([scopeId, name], name: "uq_channel_scope_name")
  @@index([scopeId], name: "idx_channel_scope_id")
}

model NotificationTask {
  id         String   @id @default(cuid())
  scopeId    String
  channelId  String?
  channelName String
  messageId  String
  messageType String
  message    Json
  status     String   @default("pending")
  lastError  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project  @relation(fields: [scopeId], references: [id], onDelete: Cascade)
  channel    NotificationChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@unique([messageId, channelId], name: "uq_tasks_message_channel")
  @@index([status, createdAt], name: "idx_tasks_status_created_at")
  @@index([status, updatedAt], name: "idx_tasks_status_updated_at")
  @@index([messageId], name: "idx_tasks_message_id")
  @@index([scopeId], name: "idx_tasks_scope_id")
  @@index([channelId], name: "idx_tasks_channel_id")
}
