{
  "name": "@code-code/console-web-provider",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "default": "./dist/components.js"
    },
    "./pages": {
      "types": "./dist/pages.d.ts",
      "default": "./dist/pages.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.11.0",
    "@code-code/agent-contract": "workspace:*",
    "@code-code/console-web-credential": "workspace:*",
    "@code-code/console-web-ui": "workspace:*",
    "@radix-ui/themes": "3.3.0",
    "recharts": "^2.15.4",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^6.22.3",
    "swr": "^2.4.1"
  },
  "peerDependencies": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "jsdom": "29.0.2",
    "typescript": "6.0.2",
    "vite": "8.0.8",
    "vitest": "4.1.4"
  }
}
