{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "partOf": { "type": "string", "minLength": 1 },
        "imageRegistry": { "type": "string" },
        "imageTag": { "type": "string", "minLength": 1 },
        "runNamespace": { "type": "string", "minLength": 1 },
        "consoleNamespace": { "type": "string", "minLength": 1 },
        "showcaseNamespace": { "type": "string", "minLength": 1 },
        "infraNamespace": { "type": "string", "minLength": 1 },
        "observabilityNamespace": { "type": "string", "minLength": 1 },
        "networkNamespace": { "type": "string", "minLength": 1 },
        "natsUrl": { "type": "string", "minLength": 1 },
        "otlpGrpcEndpoint": { "type": "string", "minLength": 1 },
        "otlpProtocol": { "type": "string", "enum": ["grpc", "http/protobuf", "http/json"] },
        "tracesEnabled": { "type": "boolean" },
        "otlpHttpEndpoint": { "type": "string", "minLength": 1 },
        "temporalAddress": { "type": "string", "minLength": 1 },
        "temporalNamespace": { "type": "string", "minLength": 1 },
        "databaseSecretName": { "type": "string", "minLength": 1 },
        "databaseSecretKey": { "type": "string", "minLength": 1 },
        "credentialEncryptionSecretName": { "type": "string", "minLength": 1 },
        "credentialEncryptionSecretKey": { "type": "string", "minLength": 1 },
        "credentialEncryptionKeyId": { "type": "string", "minLength": 1 },
        "registryAuthSecretName": { "type": "string", "minLength": 1 },
        "trustBundleConfigMapName": { "type": "string", "minLength": 1 },
        "consoleBaseUrl": { "type": "string", "minLength": 1 },
        "showcaseBaseUrl": { "type": "string", "minLength": 1 },
        "cliOutputSidecarImageName": { "type": "string", "minLength": 1 }
      },
      "required": [
        "partOf",
        "imageRegistry",
        "imageTag",
        "runNamespace",
        "consoleNamespace",
        "showcaseNamespace",
        "infraNamespace",
        "observabilityNamespace",
        "networkNamespace",
        "natsUrl",
        "otlpGrpcEndpoint",
        "otlpProtocol",
        "tracesEnabled",
        "otlpHttpEndpoint",
        "temporalAddress",
        "temporalNamespace",
        "databaseSecretName",
        "databaseSecretKey",
        "credentialEncryptionSecretName",
        "credentialEncryptionSecretKey",
        "credentialEncryptionKeyId",
        "registryAuthSecretName",
        "trustBundleConfigMapName",
        "consoleBaseUrl",
        "showcaseBaseUrl",
        "cliOutputSidecarImageName"
      ]
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "deployment": { "type": "object", "additionalProperties": true },
        "lifecycle": { "type": "object", "additionalProperties": true },
        "containerSecurityContext": { "type": "object", "additionalProperties": true },
        "resources": { "type": "object", "additionalProperties": true },
        "service": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer"] }
          },
          "required": ["type"]
        },
        "hpa": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "minReplicas": { "type": "integer", "minimum": 1 },
            "maxReplicas": { "type": "integer", "minimum": 1 },
            "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
          },
          "required": ["enabled", "minReplicas", "maxReplicas", "targetCPUUtilizationPercentage"]
        },
        "pdb": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "minAvailable": { "type": ["integer", "string"] }
          },
          "required": ["enabled", "minAvailable"]
        }
      },
      "required": ["deployment", "lifecycle", "containerSecurityContext", "resources", "service", "hpa", "pdb"]
    },
    "cliImageBuildConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "imageRegistryPrefix": { "type": "string" },
        "imageRegistryLookupPrefix": { "type": "string" },
        "imageRegistryLookupInsecure": { "type": "string", "minLength": 1 },
        "sourceContext": { "type": "string" },
        "sourceRevision": { "type": "string", "minLength": 1 }
      },
      "required": [
        "enabled",
        "imageRegistryPrefix",
        "imageRegistryLookupPrefix",
        "imageRegistryLookupInsecure",
        "sourceContext",
        "sourceRevision"
      ]
    },
    "consoleRoute": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "host": { "type": "string", "minLength": 1 },
        "extraHosts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "parentRef": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "namespace": { "type": "string", "minLength": 1 },
            "sectionName": { "type": "string", "minLength": 1 }
          },
          "required": ["name", "namespace", "sectionName"]
        }
      },
      "required": ["enabled", "host", "extraHosts", "parentRef"]
    },
    "showcaseRoute": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "host": { "type": "string", "minLength": 1 },
        "extraHosts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "parentRef": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "namespace": { "type": "string", "minLength": 1 },
            "sectionName": { "type": "string", "minLength": 1 }
          },
          "required": ["name", "namespace", "sectionName"]
        }
      },
      "required": ["enabled", "host", "extraHosts", "parentRef"]
    },
    "runtimeServiceAccounts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cliImageBuild": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "name": { "type": "string", "minLength": 1 }
          },
          "required": ["enabled", "name"]
        }
      },
      "required": ["cliImageBuild"]
    },
    "authorizationPolicies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" }
      },
      "required": ["enabled"]
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "auth": { "$ref": "#/$defs/component" },
        "model": { "$ref": "#/$defs/component" },
        "provider": { "$ref": "#/$defs/component" },
        "egress": { "$ref": "#/$defs/component" },
        "profile": { "$ref": "#/$defs/component" },
        "support": { "$ref": "#/$defs/component" },
        "cliRuntime": { "$ref": "#/$defs/component" },
        "agentRuntime": { "$ref": "#/$defs/component" },
        "chat": { "$ref": "#/$defs/component" },
        "consoleApi": { "$ref": "#/$defs/component" },
        "consoleWeb": { "$ref": "#/$defs/component" },
        "showcaseApi": { "$ref": "#/$defs/component" },
        "showcaseWeb": { "$ref": "#/$defs/component" }
      },
      "required": [
        "auth",
        "model",
        "provider",
        "egress",
        "profile",
        "support",
        "cliRuntime",
        "agentRuntime",
        "chat",
        "consoleApi",
        "consoleWeb",
        "showcaseApi",
        "showcaseWeb"
      ]
    }
  },
  "required": [
    "global",
    "defaults",
    "cliImageBuildConfig",
    "consoleRoute",
    "showcaseRoute",
    "runtimeServiceAccounts",
    "authorizationPolicies",
    "components"
  ],
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "name": { "type": "string", "minLength": 1 },
        "namespace": { "type": "string", "minLength": 1 },
        "namespaceTpl": { "type": "string", "minLength": 1 },
        "componentLabel": { "type": "string", "minLength": 1 },
        "imageName": { "type": "string", "minLength": 1 },
        "portPreset": { "type": "string", "enum": ["grpc-http", "grpc", "http"] },
        "replicas": { "type": "integer", "minimum": 0 },
        "podAutomountServiceAccountToken": { "type": "boolean" },
        "databaseUrl": { "type": "boolean" },
        "credentialEncryptionKey": { "type": "boolean" },
        "internalActionToken": { "type": "boolean" },
        "egressTrustBundle": { "type": "boolean" },
        "serviceAccount": { "type": "object", "additionalProperties": true },
        "service": { "type": "object", "additionalProperties": true },
        "containerPorts": { "type": "object", "additionalProperties": { "type": "integer" } },
        "env": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/envVar" }
        },
        "volumes": { "type": "object", "additionalProperties": true },
        "volumeMounts": { "type": "object", "additionalProperties": true },
        "probePreset": {
          "type": "string",
          "enum": [
            "grpc-8081",
            "grpc-8081-http-readyz",
            "http-readyz",
            "http-api-readyz",
            "http-healthz-fast",
            "http-api-readyz-fast"
          ]
        },
        "startupProbe": { "type": "object", "additionalProperties": true },
        "readinessProbe": { "type": "object", "additionalProperties": true },
        "livenessProbe": { "type": "object", "additionalProperties": true },
        "rbac": { "type": "object", "additionalProperties": true },
        "runtimeRbac": { "type": "object", "additionalProperties": true },
        "resources": { "type": "object", "additionalProperties": true },
        "containerSecurityContext": { "type": "object", "additionalProperties": true },
        "podSecurityContext": { "type": "object", "additionalProperties": true },
        "lifecycle": { "type": "object", "additionalProperties": true },
        "hpa": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "minReplicas": { "type": "integer", "minimum": 1 },
            "maxReplicas": { "type": "integer", "minimum": 1 },
            "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
          }
        },
        "pdb": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "minAvailable": { "type": ["integer", "string"] }
          }
        }
      },
      "required": ["enabled", "name"]
    },
    "envVar": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "value": { "type": "string" },
        "valueTpl": { "type": "string", "minLength": 1 },
        "valueFrom": { "type": "object", "additionalProperties": true }
      },
      "anyOf": [
        { "required": ["value"] },
        { "required": ["valueTpl"] },
        { "required": ["valueFrom"] }
      ]
    }
  }
}
