{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "partOf": { "type": "string", "minLength": 1 },
        "imageRegistry": { "type": "string" },
        "imageTag": { "type": "string", "minLength": 1 },
        "runNamespace": { "type": "string", "minLength": 1 },
        "infraNamespace": { "type": "string", "minLength": 1 },
        "observabilityNamespace": { "type": "string", "minLength": 1 },
        "egressGatewayNamespace": { "type": "string", "minLength": 1 },
        "egressGatewayServiceHost": { "type": "string", "minLength": 1 },
        "egressGatewaySelector": { "type": "string", "minLength": 1 },
        "natsUrl": { "type": "string", "minLength": 1 },
        "otlpGrpcEndpoint": { "type": "string", "minLength": 1 },
        "otlpProtocol": { "type": "string", "enum": ["grpc", "http/protobuf", "http/json"] },
        "tracesEnabled": { "type": "boolean" },
        "otlpHttpEndpoint": { "type": "string", "minLength": 1 },
        "temporalAddress": { "type": "string", "minLength": 1 },
        "temporalNamespace": { "type": "string", "minLength": 1 },
        "databaseSecretName": { "type": "string", "minLength": 1 },
        "databaseSecretKey": { "type": "string", "minLength": 1 },
        "registryAuthSecretName": { "type": "string", "minLength": 1 },
        "trustBundleConfigMapName": { "type": "string", "minLength": 1 },
        "consoleBaseUrl": { "type": "string", "minLength": 1 },
        "cliOutputSidecarImageName": { "type": "string", "minLength": 1 }
      },
      "required": [
        "partOf",
        "imageRegistry",
        "imageTag",
        "runNamespace",
        "infraNamespace",
        "observabilityNamespace",
        "egressGatewayNamespace",
        "egressGatewayServiceHost",
        "egressGatewaySelector",
        "natsUrl",
        "otlpGrpcEndpoint",
        "otlpProtocol",
        "tracesEnabled",
        "otlpHttpEndpoint",
        "temporalAddress",
        "temporalNamespace",
        "databaseSecretName",
        "databaseSecretKey",
        "registryAuthSecretName",
        "trustBundleConfigMapName",
        "consoleBaseUrl",
        "cliOutputSidecarImageName"
      ]
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "deployment": { "type": "object", "additionalProperties": true },
        "lifecycle": { "type": "object", "additionalProperties": true },
        "containerSecurityContext": { "type": "object", "additionalProperties": true },
        "resources": { "type": "object", "additionalProperties": true }
      },
      "required": ["deployment", "lifecycle", "containerSecurityContext", "resources"]
    },
    "cliImageBuildConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "imageRegistryPrefix": { "type": "string" },
        "imageRegistryLookupPrefix": { "type": "string" },
        "imageRegistryLookupInsecure": { "type": "string", "minLength": 1 },
        "sourceContext": { "type": "string" },
        "sourceRevision": { "type": "string", "minLength": 1 }
      },
      "required": [
        "enabled",
        "imageRegistryPrefix",
        "imageRegistryLookupPrefix",
        "imageRegistryLookupInsecure",
        "sourceContext",
        "sourceRevision"
      ]
    },
    "consoleIngress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "host": { "type": "string", "minLength": 1 },
        "extraHosts": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "tlsEnabled": { "type": "boolean" },
        "tlsSecretName": { "type": "string" },
        "sslRedirect": { "type": "boolean" }
      },
      "required": ["enabled", "host", "extraHosts", "tlsEnabled", "tlsSecretName", "sslRedirect"]
    },
    "runtimeServiceAccounts": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cliImageBuild": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "name": { "type": "string", "minLength": 1 }
          },
          "required": ["enabled", "name"]
        }
      },
      "required": ["cliImageBuild"]
    },
    "networkEgressPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "name": { "type": "string", "minLength": 1 },
        "presetProxyUrl": { "type": "string", "minLength": 1 },
        "policyJson": { "type": "string", "minLength": 1 }
      },
      "required": ["enabled", "name", "presetProxyUrl", "policyJson"]
    },
    "components": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "auth": { "$ref": "#/$defs/component" },
        "model": { "$ref": "#/$defs/component" },
        "provider": { "$ref": "#/$defs/component" },
        "network": { "$ref": "#/$defs/component" },
        "profile": { "$ref": "#/$defs/component" },
        "support": { "$ref": "#/$defs/component" },
        "cliRuntime": { "$ref": "#/$defs/component" },
        "agentRuntime": { "$ref": "#/$defs/component" },
        "chat": { "$ref": "#/$defs/component" },
        "consoleApi": { "$ref": "#/$defs/component" },
        "consoleWeb": { "$ref": "#/$defs/component" }
      },
      "required": [
        "auth",
        "model",
        "provider",
        "network",
        "profile",
        "support",
        "cliRuntime",
        "agentRuntime",
        "chat",
        "consoleApi",
        "consoleWeb"
      ]
    }
  },
  "required": [
    "global",
    "defaults",
    "cliImageBuildConfig",
    "consoleIngress",
    "runtimeServiceAccounts",
    "networkEgressPolicy",
    "components"
  ],
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "name": { "type": "string", "minLength": 1 },
        "componentLabel": { "type": "string", "minLength": 1 },
        "imageName": { "type": "string", "minLength": 1 },
        "podAutomountServiceAccountToken": { "type": "boolean" },
        "serviceAccount": { "type": "object", "additionalProperties": true },
        "service": { "type": "object", "additionalProperties": true },
        "containerPorts": { "type": "object", "additionalProperties": { "type": "integer" } },
        "env": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/envVar" }
        },
        "volumes": { "type": "object", "additionalProperties": true },
        "volumeMounts": { "type": "object", "additionalProperties": true },
        "startupProbe": { "type": "object", "additionalProperties": true },
        "readinessProbe": { "type": "object", "additionalProperties": true },
        "livenessProbe": { "type": "object", "additionalProperties": true },
        "rbac": { "type": "object", "additionalProperties": true },
        "runtimeRbac": { "type": "object", "additionalProperties": true },
        "resources": { "type": "object", "additionalProperties": true },
        "containerSecurityContext": { "type": "object", "additionalProperties": true },
        "podSecurityContext": { "type": "object", "additionalProperties": true },
        "lifecycle": { "type": "object", "additionalProperties": true }
      },
      "required": ["enabled", "name"]
    },
    "envVar": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "value": { "type": "string" },
        "valueTpl": { "type": "string", "minLength": 1 },
        "valueFrom": { "type": "object", "additionalProperties": true }
      },
      "anyOf": [
        { "required": ["value"] },
        { "required": ["valueTpl"] },
        { "required": ["valueFrom"] }
      ]
    }
  }
}
