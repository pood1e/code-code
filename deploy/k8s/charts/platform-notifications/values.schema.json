{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "partOf": { "type": "string", "minLength": 1 },
        "imageRegistry": { "type": "string" },
        "imageTag": { "type": "string", "minLength": 1 },
        "infraNamespace": { "type": "string", "minLength": 1 }
      },
      "required": ["partOf", "imageRegistry", "imageTag", "infraNamespace"]
    },
    "notificationDispatcher": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "natsUrl": { "type": "string", "minLength": 1 },
        "subject": { "type": "string", "minLength": 1 },
        "secretNames": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "appriseUrls": { "type": "string", "minLength": 1 },
            "wecomCallback": { "type": "string", "minLength": 1 },
            "wecomRobotDefaultCallback": { "type": "string", "minLength": 1 }
          },
          "required": ["appriseUrls", "wecomCallback", "wecomRobotDefaultCallback"]
        },
        "ingress": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "className": { "type": "string", "minLength": 1 },
            "proxyBodySize": { "type": "string", "minLength": 1 },
            "tlsSecretName": { "type": "string", "minLength": 1 },
            "hosts": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "minItems": 1
            }
          },
          "required": ["enabled", "className", "proxyBodySize", "tlsSecretName", "hosts"]
        },
        "dispatcher": { "$ref": "#/$defs/platformImageRef" },
        "appriseApi": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "image": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "repository": { "type": "string", "minLength": 1 },
                "tag": { "type": ["string", "number"], "minLength": 1 },
                "pullPolicy": { "type": "string", "minLength": 1 }
              },
              "required": ["repository", "tag", "pullPolicy"]
            }
          },
          "required": ["name", "image"]
        },
        "wecomCallbackAdapter": { "$ref": "#/$defs/platformImageRef" },
        "wecomRobotDefaultCallbackAdapter": { "$ref": "#/$defs/platformImageRef" }
      },
      "required": [
        "enabled",
        "natsUrl",
        "subject",
        "secretNames",
        "ingress",
        "dispatcher",
        "appriseApi",
        "wecomCallbackAdapter",
        "wecomRobotDefaultCallbackAdapter"
      ]
    }
  },
  "required": ["global", "notificationDispatcher"],
  "$defs": {
    "platformImageRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "imageName": { "type": "string", "minLength": 1 }
      },
      "required": ["name", "imageName"]
    }
  }
}
