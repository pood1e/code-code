{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "partOf": { "type": "string", "minLength": 1 },
        "platformNamespace": { "type": "string", "minLength": 1 },
        "infraNamespace": { "type": "string", "minLength": 1 },
        "observabilityNamespace": { "type": "string", "minLength": 1 },
        "observabilityAmbientPodOptOut": { "type": "boolean" },
        "networkNamespace": { "type": "string", "minLength": 1 },
        "runNamespace": { "type": "string", "minLength": 1 },
        "grafanaAdminSecretName": { "type": "string", "minLength": 1 }
      },
      "required": [
        "partOf",
        "platformNamespace",
        "infraNamespace",
        "observabilityNamespace",
        "observabilityAmbientPodOptOut",
        "networkNamespace",
        "runNamespace",
        "grafanaAdminSecretName"
      ]
    },
    "tempo": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "type": "string", "minLength": 1 },
        "dataSize": { "type": "string", "minLength": 1 }
      },
      "required": ["enabled", "image", "dataSize"]
    },
    "loki": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "type": "string", "minLength": 1 },
        "dataSize": { "type": "string", "minLength": 1 },
        "storageClassName": { "type": "string" },
        "retentionPeriod": { "type": "string", "minLength": 1 }
      },
      "required": ["enabled", "image", "dataSize", "storageClassName", "retentionPeriod"]
    },
    "alloy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "type": "string", "minLength": 1 },
        "clusterName": { "type": "string", "minLength": 1 },
        "lokiWriteUrl": { "type": "string" },
        "collectClusterEvents": { "type": "boolean" }
      },
      "required": ["enabled", "image", "clusterName", "lokiWriteUrl", "collectClusterEvents"]
    },
    "grafana": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "type": "string", "minLength": 1 },
        "nodePort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "rootUrl": { "type": "string", "minLength": 1 },
        "anonymousOrgRole": { "type": "string", "enum": ["Viewer", "Editor", "Admin"] },
        "viewersCanEdit": { "type": "boolean" },
        "exploreEnabled": { "type": "boolean" },
        "ingress": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "className": { "type": "string", "minLength": 1 },
            "host": { "type": "string", "minLength": 1 },
            "path": { "type": "string", "minLength": 1 },
            "tlsEnabled": { "type": "boolean" },
            "tlsSecretName": { "type": "string" }
          },
          "required": ["enabled", "className", "host", "path", "tlsEnabled", "tlsSecretName"]
        }
      },
      "required": ["enabled", "image", "nodePort", "rootUrl", "anonymousOrgRole", "viewersCanEdit", "exploreEnabled", "ingress"]
    },
    "cloudflareDdns": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "image": { "type": "string", "minLength": 1 },
        "configMapName": { "type": "string", "minLength": 1 },
        "secretName": { "type": "string", "minLength": 1 },
        "domains": { "type": "string", "minLength": 1 },
        "proxied": { "type": "string", "minLength": 1 },
        "ip4Provider": { "type": "string", "minLength": 1 },
        "ip6Provider": { "type": "string", "minLength": 1 },
        "updateCron": { "type": "string", "minLength": 1 },
        "updateOnStart": { "type": "string", "minLength": 1 }
      },
      "required": [
        "enabled",
        "image",
        "configMapName",
        "secretName",
        "domains",
        "proxied",
        "ip4Provider",
        "ip6Provider",
        "updateCron",
        "updateOnStart"
      ]
    },
    "kiali": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "crEnabled": { "type": "boolean" },
        "name": { "type": "string", "minLength": 1 },
        "nodePort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "servicePort": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "webRoot": { "type": "string", "minLength": 1 },
        "ingress": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "className": { "type": "string", "minLength": 1 },
            "host": { "type": "string", "minLength": 1 },
            "path": { "type": "string", "minLength": 1 },
            "tlsEnabled": { "type": "boolean" },
            "tlsSecretName": { "type": "string" }
          },
          "required": ["enabled", "className", "host", "path", "tlsEnabled", "tlsSecretName"]
        }
      },
      "required": ["enabled", "name", "nodePort", "servicePort", "webRoot", "ingress"]
    }
  },
  "required": ["global", "tempo", "loki", "alloy", "grafana", "cloudflareDdns", "kiali"]
}
