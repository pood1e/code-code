#!/usr/bin/env bash
# Copy to deploy/local.proxy.sh (gitignored) and adjust for your local network.

PROXY_URL="http://127.0.0.1:7890"

BUILD_HTTP_PROXY="${BUILD_HTTP_PROXY:-${PROXY_URL}}"
BUILD_HTTPS_PROXY="${BUILD_HTTPS_PROXY:-${PROXY_URL}}"

if [ -n "${BUILD_NO_PROXY:-}" ]; then
  BUILD_NO_PROXY="${BUILD_NO_PROXY},localhost,127.0.0.1,.svc,.cluster.local"
else
  BUILD_NO_PROXY="localhost,127.0.0.1,.svc,.cluster.local"
fi

# Runtime egress proxy endpoint for in-cluster preset-proxy.
# PLATFORM_EGRESS_PRESET_PROXY_URL="${PLATFORM_EGRESS_PRESET_PROXY_URL:-http://host.lima.internal:10809}"
