# Infrastructure examples used when applying the infra components manually.
POSTGRES_PASSWORD="<REPLACE_WITH_POSTGRES_PASSWORD>"
DATABASE_URL="postgres://code_code:<REPLACE_WITH_POSTGRES_PASSWORD>@postgres.code-code-infra.svc.cluster.local:5432/code_code?sslmode=disable"
GRAFANA_ADMIN_USER="<REPLACE_WITH_GRAFANA_ADMIN_USER>"
GRAFANA_ADMIN_PASSWORD="<REPLACE_WITH_GRAFANA_ADMIN_PASSWORD>"
IMAGE_REGISTRY="registry.example.com/platform/"
CLI_RUNTIME_IMAGE_REGISTRY_PREFIX="${IMAGE_REGISTRY}"
CLI_RUNTIME_IMAGE_REGISTRY_LOOKUP_PREFIX="${CLI_RUNTIME_IMAGE_REGISTRY_PREFIX}"
CLI_RUNTIME_IMAGE_REGISTRY_LOOKUP_INSECURE="false"
CLI_RUNTIME_IMAGE_BUILD_SOURCE_CONTEXT="https://git.example.com/platform/code-code.git"
CLI_RUNTIME_IMAGE_BUILD_SOURCE_REVISION="main"
