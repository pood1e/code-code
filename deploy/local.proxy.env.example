# Copy to deploy/local.proxy.env (gitignored) and adjust values as needed.
# BUILD_HTTP_PROXY=http://127.0.0.1:7890
# BUILD_HTTPS_PROXY=http://127.0.0.1:7890
# BUILD_NO_PROXY=localhost,127.0.0.1,.svc,.cluster.local
#
# Runtime egress proxy for platform egress policy (inside cluster).
# For Colima/K3s, prefer host.lima.internal to reach macOS host.
# PLATFORM_EGRESS_PRESET_PROXY_URL=http://host.lima.internal:10809

# Optional local ingress host overrides (gitignored local file only).
# LOCAL_INGRESS_BIND_IP generates:
#   console.<ip>.nip.io
#   kiali.<ip>.nip.io
#   grafana.<ip>.nip.io
# LOCAL_INGRESS_BIND_IP=<LAN_IP>
#
# Or set explicit hosts:
# CONSOLE_INGRESS_HOST=console.<LAN_IP>.nip.io
# Optional comma-separated aliases published by the same ingress:
# CONSOLE_INGRESS_EXTRA_HOSTS=console.localhost
# KIALI_INGRESS_HOST=kiali.<LAN_IP>.nip.io
# GRAFANA_INGRESS_HOST=grafana.<LAN_IP>.nip.io
